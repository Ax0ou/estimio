<h2>Interagir avec l'IA 🤖</h2>

<%= form_for [@quote, @ai_message], local: true, html: { data: { controller: "audio", audio_quote_id_value: @quote.id } } do |form| %>
  <div class="mb-3">
    <%= form.label :description %>
    <%= form.text_field :description, class: "form-control" %>
  </div>

  <div class="card mb-4 shadow-sm">
    <div class="card-body">
      <h5 class="card-title">🎤 Ajouter une note vocale</h5>
      <p class="card-text text-muted">Appuie sur le bouton pour enregistrer ta voix.</p>

      <button
        type="button"
        data-audio-target="button"
        data-action="click->audio#toggleRecording"
        class="btn btn-outline-primary w-100"
      >
        🎙️ Start Recording
      </button>

      <audio
        data-audio-target="preview"
        controls
        class="mt-3 w-100"
        style="display: none;"
      ></audio>

      <input
        type="hidden"
        data-audio-target="input"
        name="audio"
      >
    </div>
  </div>

  <button
    type="button"
    data-action="click->audio#sendToTranscription"
    class="btn btn-primary"
  >
    Envoyer
  </button>
<% end %>
